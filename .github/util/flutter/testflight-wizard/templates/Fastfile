# ============================================
# Fastfile for iOS TestFlight Deployment
# ============================================
#
# 이 파일은 flutter-ios-testflight-init 마법사에 의해 생성됩니다.
# GitHub Actions 워크플로우에서 이 파일을 직접 사용합니다.
#
# 빌드 파이프라인:
#   1. flutter build ios --no-codesign (Flutter 빌드)
#   2. xcodebuild archive (Xcode 아카이브 생성)
#   3. xcodebuild -exportArchive (IPA 생성)
#   4. fastlane upload_testflight (이 파일의 lane 실행)
#
# 필요한 환경변수:
#   - APP_STORE_CONNECT_API_KEY_ID: App Store Connect API Key ID
#   - APP_STORE_CONNECT_ISSUER_ID: App Store Connect Issuer ID
#   - API_KEY_PATH: API Key 파일 경로 (.p8)
#   - IPA_PATH: 업로드할 IPA 파일 경로
#   - RELEASE_NOTES: 릴리즈 노트 (한국어/영어 동시 적용)
#   - APP_IDENTIFIER: 앱 Bundle ID (예: com.example.app)
#       └ appstore_submit 모드에서 deliver가 빌드를 특정하는 데 필수.
#         없으면 "Could not infer your App's Bundle Identifier"로 비대화형 crash.
#   - DEPLOY_MODE: 배포 모드 (선택, 기본 testflight_only)
#       └ testflight_only : TestFlight 업로드까지만 (기본·안전값)
#       └ appstore_submit : pilot 후 deliver로 App Store production 심사 자동 제출
#
# 사용법 (CI):
#   fastlane deploy              # DEPLOY_MODE에 따라 분기 (권장 진입점)
#   fastlane upload_testflight   # TestFlight 업로드만 (DEPLOY_MODE 무시)
#
# 사용법 (로컬):
#   bundle exec fastlane upload_testflight
#   bundle exec fastlane build_and_deploy changelog:"릴리즈 노트"
#
# ============================================

default_platform(:ios)

platform :ios do
  # ──────────────────────────────────────────────────────────────
  # 통합 진입점: DEPLOY_MODE로 "TestFlight만" / "App Store 심사까지"를 제어
  #   - testflight_only(기본): pilot(TestFlight 업로드)까지만
  #   - appstore_submit      : pilot 후 deliver로 App Store production 심사 자동 제출
  # 워크플로우는 이 lane(`fastlane deploy`)을 호출하면 모드에 따라 알아서 분기된다.
  # ──────────────────────────────────────────────────────────────
  desc "배포 (DEPLOY_MODE: testflight_only | appstore_submit)"
  lane :deploy do
    deploy_mode = (ENV["DEPLOY_MODE"] || "testflight_only").strip
    submit_to_appstore = (deploy_mode == "appstore_submit")
    UI.message("🎛️  배포 모드: #{deploy_mode} (App Store 심사 제출: #{submit_to_appstore})")

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    app_id = ENV["APP_IDENTIFIER"]
    if submit_to_appstore && (app_id.nil? || app_id.empty?)
      UI.user_error!("appstore_submit 모드에는 APP_IDENTIFIER(Bundle ID)가 필요합니다. ENV로 전달하세요.")
    end

    ipa_path = ENV["IPA_PATH"]
    ipa_path = Dir.glob("build/ipa/*.ipa").first if ipa_path.nil? || ipa_path.empty?
    UI.message("📦 IPA 경로: #{ipa_path}")

    # Ruby 3.4+ frozen string 호환성: .dup으로 mutable 복사본 생성
    release_notes = (ENV["RELEASE_NOTES"] || "새로운 빌드가 업로드되었습니다.").dup

    # 1) TestFlight 업로드 (항상 수행)
    #    심사 제출 모드면 deliver가 빌드를 찾을 수 있도록 처리 완료까지 대기
    pilot_args = {
      api_key: api_key,
      ipa: ipa_path,
      changelog: release_notes,
      localized_build_info: {
        "ko" => { whats_new: release_notes.dup },
        "en-US" => { whats_new: release_notes.dup }
      },
      skip_waiting_for_build_processing: !submit_to_appstore,
      distribute_external: false,
      notify_external_testers: false,
      uses_non_exempt_encryption: ENV["USES_NON_EXEMPT_ENCRYPTION"] == "true"
    }
    pilot_args[:app_identifier] = app_id unless app_id.nil? || app_id.empty?
    upload_to_testflight(pilot_args)
    UI.success("✅ TestFlight 업로드 완료!")

    # 2) App Store production 심사 자동 제출 (appstore_submit 모드에서만)
    #    빌드만 제출하되, 새 버전 심사에 필수인 릴리스 노트(whatsNew)는 채운다.
    if submit_to_appstore
      notes = (ENV["RELEASE_NOTES"] || "버그를 수정하고 안정성을 개선했습니다.").strip
      notes = "버그를 수정하고 안정성을 개선했습니다." if notes.empty?

      # App Store는 업데이트 버전 심사 제출 시 whatsNew(릴리스 노트)를 필수로 요구한다.
      # release_notes.txt만 만들고 다른 메타 파일은 안 만든다 → ASC 기존 메타(설명/키워드 등)는 보존.
      # ASC 앱 로케일에 맞춰 ko / ko-KR 양쪽 작성(로케일 코드 불일치 방어). 필요시 en-US 등 추가.
      require "fileutils"
      metadata_path = "./fastlane/metadata"
      (ENV["DELIVER_LOCALES"] || "ko,ko-KR").split(",").map(&:strip).each do |loc|
        next if loc.empty?
        FileUtils.mkdir_p("#{metadata_path}/#{loc}")
        File.write("#{metadata_path}/#{loc}/release_notes.txt", notes)
      end

      deliver(
        api_key: api_key,
        app_identifier: app_id,            # Bundle ID 명시 (비대화형 추론 실패 방지)
        app_version: ENV["APP_VERSION"],   # 해당 버전의 editable App Store 버전 생성/선택 (없으면 submit 불가)
        submit_for_review: true,           # 심사 자동 제출
        automatic_release: true,           # 심사 통과 즉시 자동 출시
        force: true,                       # CI 비대화형: HTML 미리보기 확인 건너뜀
        run_precheck_before_submit: false, # precheck 비대화형 충돌 방지
        skip_binary_upload: true,          # pilot으로 올린 빌드 사용 (재업로드 안 함)
        skip_metadata: false,              # release_notes(whatsNew)만 업로드 (다른 메타 파일 없음 → 기존값 보존)
        metadata_path: metadata_path,
        skip_screenshots: true,            # 스샷은 App Store Connect 웹에서 관리
        precheck_include_in_app_purchases: false,
        submission_information: {
          add_id_info_uses_idfa: false     # 광고 식별자 미사용 (심사 질문 자동 응답)
        }
      )
      UI.success("✅ App Store 심사 제출 완료!")
    else
      UI.message("⏭️  testflight_only 모드 — App Store 심사 제출 건너뜀")
    end
  end

  desc "TestFlight에 IPA 업로드 (CI용 - IPA가 이미 빌드된 상태)"
  lane :upload_testflight do
    UI.message("🚀 TestFlight 업로드 시작")

    # App Store Connect API Key 설정
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    # IPA 파일 확인
    ipa_path = ENV["IPA_PATH"]
    if ipa_path.nil? || ipa_path.empty?
      ipa_path = Dir.glob("build/ipa/*.ipa").first
    end

    UI.message("📦 IPA 경로: #{ipa_path}")

    # 릴리즈 노트 설정
    # Ruby 3.4+ frozen string 호환성: .dup으로 mutable 복사본 생성
    release_notes = (ENV["RELEASE_NOTES"] || "새로운 빌드가 업로드되었습니다.").dup
    UI.message("📝 릴리즈 노트: #{release_notes}")

    # TestFlight 업로드 (upload_to_testflight = pilot)
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      changelog: release_notes,
      # Ruby 3.4+ frozen string 호환성: localized_build_info 내부 문자열도 .dup 적용
      localized_build_info: {
        "ko" => { whats_new: release_notes.dup },
        "en-US" => { whats_new: release_notes.dup }
      },
      skip_waiting_for_build_processing: ENV["SKIP_WAITING_FOR_BUILD_PROCESSING"] == "true",
      distribute_external: false,
      notify_external_testers: false,
      uses_non_exempt_encryption: ENV["USES_NON_EXEMPT_ENCRYPTION"] == "true"
    )

    UI.success("✅ TestFlight 업로드 완료!")
  end

  desc "로컬에서 IPA 빌드 및 TestFlight 업로드 (개발용)"
  lane :build_and_deploy do |options|
    UI.message("🏗️ 로컬 빌드 및 배포 시작")
    
    # App Store Connect API Key 설정
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    # Archive 생성
    UI.message("📦 Archive 생성 중...")
    sh("xcodebuild -workspace Runner.xcworkspace " \
       "-scheme Runner " \
       "-archivePath build/Runner.xcarchive " \
       "-destination 'generic/platform=iOS' " \
       "archive " \
       "CODE_SIGN_STYLE=Manual " \
       "PROVISIONING_PROFILE_SPECIFIER='#{ENV['IOS_PROVISIONING_PROFILE_NAME']}' " \
       "CODE_SIGN_IDENTITY='Apple Distribution'")

    # IPA 내보내기
    UI.message("📦 IPA 내보내기 중...")
    sh("xcodebuild -exportArchive " \
       "-archivePath build/Runner.xcarchive " \
       "-exportPath build/ipa " \
       "-exportOptionsPlist ExportOptions.plist")

    # TestFlight 업로드
    ipa_path = Dir.glob("build/ipa/*.ipa").first
    # Ruby 3.4+ frozen string 호환성: .dup으로 mutable 복사본 생성
    changelog = (options[:changelog] || "새로운 빌드가 업로드되었습니다.").dup
    pilot(
      api_key: api_key,
      ipa: ipa_path,
      changelog: changelog,
      skip_waiting_for_build_processing: ENV["SKIP_WAITING_FOR_BUILD_PROCESSING"] == "true",
      distribute_external: false,
      notify_external_testers: false,
      uses_non_exempt_encryption: false
    )

    UI.success("✅ 빌드 및 TestFlight 업로드 완료!")
  end
end
